# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cosmetic-shop

# ── Authentication ────────────────────────────────────────────────────────────
# Tạo JWT_SECRET mạnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production
# Secret riêng cho refresh token (nên khác với JWT_SECRET để tăng bảo mật)
# Nếu không set, hệ thống dùng JWT_SECRET + "_refresh" làm fallback
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL của frontend (không có dấu / ở cuối)
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# true  → tắt hoàn toàn (dùng khi dev/test)
# false → bật (dùng trong production)
DISABLE_RATE_LIMIT=true

# ── Email (SendGrid) ───────────────────────────────────────
# Lấy API key tại: app.sendgrid.com
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=GlowUp Cosmetics <no-reply@yourdomain.com>

# ── VNPay (Thanh toán) ────────────────────────────────────────────────────────
VNP_TMN_CODE=your_tmn_code_here
VNP_HASH_SECRET=your_hash_secret_here
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_API=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNP_RETURN_URL=http://localhost:5173/checkout/vnpay_return

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Dùng để tạo link reset password trong email
FRONTEND_URL=http://localhost:5173
